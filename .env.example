# Cut Sew Print — environment variables
# Copy to .env.local and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings → API.

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose to the browser. Powers username-only password
# recovery (admin password reset). Find it in Supabase: Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
